# Stripe test-mode keys — copy this file to .env.local and paste your keys.
# Get them at https://dashboard.stripe.com/test/apikeys (toggle "Test mode" on).

# Secret key (server only — NEVER exposed to the browser). Starts with sk_test_
STRIPE_SECRET_KEY=sk_test_xxx

# Publishable key (safe for the browser). Starts with pk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Clerk authentication — get keys at https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
